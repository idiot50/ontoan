# Sao chép thành .env trên SERVER (chmod 600). KHÔNG commit .env.
# Lấy 3 khóa trong PayOS Dashboard -> Kênh thanh toán -> Thông tin API.
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=

# Cấu hình (mặc định đã hợp lý)
PORT=8787
ALLOWED_ORIGIN=https://idiot50.github.io
AMOUNT=10000
DESCRIPTION=Ung ho Toan Vui
RETURN_URL=https://idiot50.github.io/ontoan/?ung_ho=ok
CANCEL_URL=https://idiot50.github.io/ontoan/?ung_ho=huy
